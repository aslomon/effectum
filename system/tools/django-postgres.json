{
  "name": "Django + PostgreSQL Tools",
  "description": "Tools for Django with PostgreSQL stack projects.",
  "tools": [
    {
      "key": "python3",
      "bin": "python3",
      "displayName": "Python 3",
      "category": "runtime",
      "why": "Python runtime required for Django",
      "priority": 0,
      "autoInstall": false,
      "install": {
        "darwin": "brew install python@3.12",
        "linux": "sudo apt install -y python3.12 python3.12-venv"
      },
      "check": "python3 --version",
      "manualUrl": "https://www.python.org/downloads/"
    },
    {
      "key": "uv",
      "bin": "uv",
      "displayName": "uv",
      "category": "stack",
      "why": "Fast Python package management and virtual environment handling",
      "priority": 1,
      "autoInstall": true,
      "install": {
        "all": "curl -LsSf https://astral.sh/uv/install.sh | sh"
      },
      "check": "uv --version"
    },
    {
      "key": "ruff",
      "bin": "ruff",
      "displayName": "Ruff",
      "category": "stack",
      "why": "Python linting and formatting",
      "priority": 2,
      "autoInstall": true,
      "install": {
        "all": "pip install ruff"
      },
      "check": "ruff --version"
    },
    {
      "key": "docker",
      "bin": "docker",
      "displayName": "Docker",
      "category": "stack",
      "why": "Required for running PostgreSQL locally via docker compose",
      "priority": 3,
      "autoInstall": false,
      "install": {
        "darwin": "brew install --cask docker",
        "linux": "sudo apt install -y docker.io docker-compose-plugin"
      },
      "check": "docker --version",
      "manualUrl": "https://docs.docker.com/get-docker/"
    }
  ]
}
