{
  "env": {
    "node": true,
    "commonjs": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-const-assign": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-unreachable": "warn",
    "eqeqeq": ["warn", "always"],
    "no-var": "warn",
    "prefer-const": "warn"
  },
  "ignorePatterns": ["node_modules/", "test/"]
}
